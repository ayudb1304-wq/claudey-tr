# ─────────────────────────────────────────────────────
#  COPY THIS FILE TO .env AND FILL IN YOUR REAL VALUES
#  Never commit .env to git — it contains your secrets
# ─────────────────────────────────────────────────────

# Angel One SmartAPI credentials
# Get these from: https://smartapi.angelbroking.com/
ANGEL_ONE_API_KEY=your_api_key_here
ANGEL_ONE_CLIENT_ID=your_client_id_here

# Your Angel One MPIN (the 4–6 digit PIN you use to log in on the app)
ANGEL_ONE_PASSWORD=your_mpin_here

# TOTP Secret Key (Base32 string — NOT the 6-digit code)
# How to find it: When setting up Google Authenticator for Angel One,
# they show a QR code AND a text key (like "JBSWY3DPEHPK3PXP").
# That text key is your TOTP secret. Save it here.
ANGEL_ONE_TOTP_SECRET=your_totp_base32_secret_here

# Anthropic API key (Claude)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
